{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

# Ensure brew is on PATH (Apple Silicon installs to /opt/homebrew)
if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

{{ include (joinPath .chezmoi.sourceDir ".chezmoitemplates/scripts-library.sh") -}}

{{ $current_shell := env "SHELL" -}}
{{ if eq $current_shell "/opt/homebrew/bin/zsh" -}}
    exit 0
{{ end }}

if ask_user "Change default shell to zsh?"; then
    current_user=$USER
    echo "Changing shell for current user to zsh"
    sudo chsh -s "$(brew --prefix)"/bin/zsh $current_user
fi

{{ end -}}
