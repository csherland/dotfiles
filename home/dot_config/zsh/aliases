# ls replacement
alias ls='eza'
alias lt='eza --tree --level=2 --long --icons --git'
alias l='eza --long --icons --git -a'

# program shortcuts
alias cz='chezmoi'
alias lg='lazygit'
# yazi wrapper - cd into last browsed directory on quit
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}
alias rr='y'
alias vim='nvim'
alias cat='bat'
alias top='btop'
